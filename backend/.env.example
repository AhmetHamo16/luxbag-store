NODE_ENV=production
PORT=5000
CLIENT_URL=https://your-frontend-domain.com
CLIENT_URLS=https://your-frontend-domain.com,https://www.your-frontend-domain.com
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/melora?retryWrites=true&w=majority
JWT_SECRET=replace_with_a_long_random_secret
JWT_REFRESH_SECRET=replace_with_a_second_long_random_secret

EMAIL_HOST=smtp.resend.com
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=resend
EMAIL_PASS=replace_with_email_password
EMAIL_FROM=orders@your-domain.com

CLOUDINARY_CLOUD_NAME=replace_with_cloud_name
CLOUDINARY_API_KEY=replace_with_cloudinary_key
CLOUDINARY_API_SECRET=replace_with_cloudinary_secret

STORE_NAME=Melora Luxury
STORE_EMAIL=support@your-domain.com
STORE_PHONE=+90XXXXXXXXXX
